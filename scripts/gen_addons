#!/usr/bin/env ruby
# frozen_string_literal: true

# Usage
# $ ./gen_addons addons.json > addons.nix

require "json"
require "tmpdir"
require "fileutils"
require "open3"
require "etc"
require "shellwords"
require "tempfile"
require "thread"

def command_exists?(cmd)
  system("command -v #{Shellwords.escape(cmd)} >/dev/null 2>&1")
end

def run_cmd(*cmd, allow_failure: false, chdir: nil, env: {})
  opts = {}
  opts[:chdir] = chdir if chdir

  stdout, stderr, status = Open3.capture3(env, *cmd, **opts)

  if !status.success? && !allow_failure
    raise "Command failed: #{cmd.join(' ')}\n#{stderr}"
  end

  [stdout, stderr, status]
end

def usage!
  warn "Usage: #{$PROGRAM_NAME} <addons.json>"
  exit 1
end

def extract_repo(url)
  match = url.match(%r{^https?://github\.com/([^/]+)/([^/]+)})
  return nil unless match

  owner = match[1]
  repo = match[2].sub(/\.git$/, "")
  "#{owner}/#{repo}"
end

def find_first_toc(dir)
  Dir.glob(File.join(dir, "**", "*.toc"), File::FNM_CASEFOLD).sort.first
end

def common_name(repo)
  repo.downcase.tr("/", ".")
end

def escape_nix_string(str)
  str.gsub("\\", "\\\\\\").gsub('"', '\"')
end

def determine_sha(owner, repo_name, repo, rev, checkout_dir)
  if command_exists?("nix")
    FileUtils.rm_rf(File.join(checkout_dir, ".git"))
    stdout, = run_cmd(
      "nix",
      "--extra-experimental-features", "nix-command",
      "hash", "path", checkout_dir
    )
    stdout.strip
  elsif command_exists?("nix-prefetch-github")
    stdout, = run_cmd(
      "nix-prefetch-github",
      "--owner", owner,
      "--repo", repo_name,
      "--rev", rev,
      "--quiet"
    )
    JSON.parse(stdout)["sha256"]
  elsif command_exists?("nix-build")
    nix_file = Tempfile.new(["prefetch", ".nix"])
    begin
      nix_file.write(<<~NIX)
        with import <nixpkgs> {};
        let
          src = fetchgit {
            url = "https://github.com/#{repo}.git";
            rev = "#{rev}";
            sha256 = lib.fakeSha256;
          };
        in src
      NIX
      nix_file.close

      _stdout, stderr, = run_cmd("nix-build", nix_file.path, allow_failure: true)
      got_line = stderr.lines.find { |line| line.include?("got:") }
      got_line&.split&.at(1)&.strip
    ensure
      nix_file.close!
    end
  end
end

def process_repo(repo)
  warn "Setting up #{repo}..."

  owner, repo_name = repo.split("/", 2)

  Dir.mktmpdir("addon_checkout") do |checkout_dir|
    _stdout, _stderr, status = run_cmd(
      "git", "clone", "--depth", "1", "https://github.com/#{repo}.git", checkout_dir,
      allow_failure: true,
      env: {
        "GIT_TERMINAL_PROMPT" => "0",
        "GIT_ASKPASS" => "/bin/true"
      }
    )

    unless status.success?
      warn "Unable to clone #{repo}. Skipping"
      return nil
    end

    rev, = run_cmd("git", "-C", checkout_dir, "rev-parse", "HEAD")
    rev = rev.strip

    sha = determine_sha(owner, repo_name, repo, rev, checkout_dir)
    if sha.nil? || sha.empty? || sha == "null"
      warn "Unable to determine sha256 for #{repo}. Skipping"
      return nil
    end

    tocname = find_first_toc(checkout_dir)
    if tocname.nil? || tocname.empty?
      warn "Unable to find .toc file in repository #{repo}. Skipping"
      return nil
    end

    name = File.basename(tocname, ".toc")
    attr_name = common_name(repo)

    <<~NIX.chomp
        #{attr_name} = { name = "#{escape_nix_string(name)}"; owner = "#{escape_nix_string(owner)}"; repo = "#{escape_nix_string(repo_name)}"; rev = "#{escape_nix_string(rev)}"; sha256 = "#{escape_nix_string(sha)}"; };
    NIX
  end
rescue => e
  warn "Error processing #{repo}: #{e.message}"
  nil
end

unless command_exists?("git")
  warn "Error: git is not installed."
  exit 1
end

unless command_exists?("nix") || command_exists?("nix-prefetch-github") || command_exists?("nix-build")
  warn "Error: nix, nix-prefetch-github, or nix-build is required."
  exit 1
end

usage! unless ARGV.length == 1

input_file = ARGV[0]
unless File.file?(input_file)
  warn "Error: File '#{input_file}' not found."
  exit 1
end

repos =
  begin
    data = JSON.parse(File.read(input_file))
    unless data.is_a?(Array)
      warn "Error: JSON input must be an array of GitHub URLs."
      exit 1
    end

    data.filter_map { |url| extract_repo(url.to_s) }.uniq.sort
  rescue JSON::ParserError => e
    warn "Error: Failed to parse JSON: #{e.message}"
    exit 1
  end

max_threads = Integer(ENV.fetch("JOBS", "5"))
clone_stagger = Float(ENV.fetch("CLONE_STAGGER", "1.5"))

queue = Queue.new
repos.each { |repo| queue << repo }

results = []
results_mutex = Mutex.new
start_mutex = Mutex.new
next_start_time = Time.now

workers = Array.new(max_threads) do
  Thread.new do
    loop do
      repo =
        begin
          queue.pop(true)
        rescue ThreadError
          nil
        end

      break if repo.nil?

      start_mutex.synchronize do
        now = Time.now
        sleep_time = next_start_time - now
        sleep(sleep_time) if sleep_time > 0
        next_start_time = Time.now + clone_stagger
      end

      nix_snippet = process_repo(repo)
      next unless nix_snippet

      results_mutex.synchronize do
        results << nix_snippet
      end
    end
  end
end

begin
  workers.each(&:join)
rescue Interrupt
  warn "\nInterrupted, stopping..."
  workers.each(&:kill)
  exit 130
end

puts "{ ... }:"
puts "{"
results.sort.each { |line| puts line }
puts "}"
